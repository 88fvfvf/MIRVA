# ─────────────────────────────────────────────────────────────────────────────
# MIVRA Bot — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Environment ──────────────────────────────────────────────────────────────
# Controls logging verbosity and safety guards.
# Values: development | staging | production
NODE_ENV=development

# ── Telegram Bot ─────────────────────────────────────────────────────────────
BOT_TOKEN=your_telegram_bot_token_here
ADMIN_ID=your_telegram_user_id_here

# ── Paycom / Payme Gateway ───────────────────────────────────────────────────
# TEST tokens (safe for development — will never charge real money):
PAYCOM_TOKEN=371317599:TEST:your_test_token_here
PAYCOM_MERCHANT_ID=

# PRODUCTION tokens (set ONLY in production environment):
# PAYCOM_TOKEN=your_live_merchant_key_here
# PAYCOM_MERCHANT_ID=your_24char_merchant_id_here

# Paycom IP Allowlist (comma-separated CIDRs).
# Leave blank to skip IP filtering (not recommended for production).
# Official Paycom IPs — verify with Paycom dashboard before deploying.
# Example: PAYCOM_ALLOWED_IPS=185.8.212.0/24,91.204.228.0/24
PAYCOM_ALLOWED_IPS=

# ── Logging ──────────────────────────────────────────────────────────────────
# File path for persistent log output (leave blank = stdout only).
# Example: ./logs/mivra.log
LOG_FILE=./logs/mivra.log

# Minimum log level: debug | info | warn | error
# Default: 'info' in production, 'debug' in development.
LOG_LEVEL=debug

# ── Database ─────────────────────────────────────────────────────────────────
# Path to the SQLite database file.
DB_PATH=./mivra.db

# ── Backup ───────────────────────────────────────────────────────────────────
# Directory where daily transaction backups are stored.
BACKUP_DIR=./backups
